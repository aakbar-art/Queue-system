# --- apps/web (.env in apps/web or symlink) ---
VITE_QUEUE_BACKEND=0
# Set to 1 to sync queue snapshot with API (requires server running)
VITE_API_BASE_URL=/api

# --- server (.env in server/) ---
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Optional: SQL Server — set SQL_SERVER + SQL_DATABASE to persist queue snapshot in [ops].[QueueSnapshot]
# Leave SQL_SERVER empty to use file-based snapshot only (server/data/snapshot.json).
SQL_SERVER=
SQL_DATABASE=ArcEdge Queue
SQL_USER=
SQL_PASSWORD=
# Integrated auth not wired in pool yet; use SQL_USER/SQL_PASSWORD for now.
SQL_USE_WINDOWS_AUTH=false
SQL_ENCRYPT=true
SQL_TRUST_CERT=true
