{
  "name": "arcedge-queue",
  "private": true,
  "workspaces": ["apps/web", "server"],
  "scripts": {
    "start": "npm run dev",
    "dev": "concurrently -k -n web,api -c cyan,magenta \"npm run dev -w apps/web\" \"npm run dev -w server\"",
    "dev:web": "npm run dev -w apps/web",
    "dev:server": "npm run dev -w server",
    "build": "npm run build -w apps/web && npm run build -w server",
    "lint": "npm run lint -w apps/web && npm run lint -w server",
    "format": "prettier --write .",
    "seed": "node scripts/seed-demo-state.mjs"
  },
  "devDependencies": {
    "bcryptjs": "^3.0.2",
    "@eslint/js": "^9.32.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.1",
    "prettier": "^3.7.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1"
  }
}
