PORT=3001
CORS_ORIGIN=http://localhost:5173

# Leave SQL_SERVER empty to use file-based snapshots only (server/data/snapshot.json).
#
# Windows (SQL Express): SQL_SERVER=localhost\SQLEXPRESS — leave SQL_USER empty for
# Windows integrated auth via ODBC (requires msnodesqlv8 + ODBC Driver 17/18).
# Optional: SQL_ODBC_DRIVER=ODBC Driver 18 for SQL Server
#
# SQL authentication (mixed mode on the instance): set SQL_USER and SQL_PASSWORD.
# SQL_SERVER=localhost\SQLEXPRESS
# SQL_DATABASE=ArcEdge Queue
# SQL_USER=sa
# SQL_PASSWORD=YourStrong_Passw0rd
SQL_SERVER=
SQL_DATABASE=ArcEdge Queue
SQL_USER=
SQL_PASSWORD=
SQL_ENCRYPT=true
SQL_TRUST_CERT=true
